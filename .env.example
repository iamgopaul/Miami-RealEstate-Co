# ── Server ──────────────────────────────────────────────────────────────
PORT=3000

# ── Google Sheets ────────────────────────────────────────────────────────
# Sheet URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEET_NAME=Leads
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# ── Resend (email) ───────────────────────────────────────────────────────
# Sign up at resend.com — free tier: 3,000 emails/month
# For testing use the default "onboarding@resend.dev" sender (no domain needed)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Once you verify a domain: "Miami Properties <noreply@yourdomain.com>"
RESEND_FROM=Miami Properties <onboarding@resend.dev>
OWNER_EMAIL=joshgopaul91@gmail.com

# ── Twilio WhatsApp (optional) ───────────────────────────────────────────
# Sign up at twilio.com — use the Sandbox for instant testing:
#   console.twilio.com → Messaging → Try it out → Send a WhatsApp message
#   Text "join <sandbox-word>" from your phone to activate the sandbox
# Leave blank to disable WhatsApp notifications
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=14155238886
OWNER_WHATSAPP=13055551234
