# ── Server ──────────────────────────────────────────────────────────────
PORT=3000

# ── Google Sheets ────────────────────────────────────────────────────────
# The ID from your Sheet URL:
#   https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# The exact tab name (default: Leads)
GOOGLE_SHEET_NAME=Leads

# From your service account JSON file (credentials.json → client_email)
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# From your service account JSON file (credentials.json → private_key)
# Paste the full key including -----BEGIN/END----- lines
# If pasting into a .env file, replace actual newlines with \n
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
